  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "ToolResponse": {
        "$defs": {
          "ToolResponse": {
            "type": "object",
            "required": [
              "ok"
            ],
            "properties": {
              "ok": {
                "type": "boolean"
              },
              "data": {
                "$id": "/schemas/unknown",
                "title": "unknown"
              },
              "error": {
                "$ref": "#/$defs/ErrorBody"
              },
              "receipt": {
                "$ref": "#/$defs/Receipt"
              },
              "_links": {
                "type": "object",
                "required": [],
                "properties": {},
                "additionalProperties": {
                  "$id": "/schemas/unknown",
                  "title": "unknown"
                }
              }
            },
            "additionalProperties": false
          },
          "ErrorBody": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "$id": "/schemas/unknown",
                "title": "unknown"
              }
            },
            "additionalProperties": false
          },
          "Receipt": {
            "type": "object",
            "required": [
              "service",
              "contractVersion",
              "primitive",
              "timestamp"
            ],
            "properties": {
              "service": {
                "type": "string"
              },
              "contractVersion": {
                "type": "string"
              },
              "primitive": {
                "$ref": "#/$defs/PrimitiveName"
              },
              "eventId": {
                "type": "string"
              },
              "sessionId": {
                "type": "string"
              },
              "runtime": {
                "$ref": "#/$defs/RuntimeName"
              },
              "store": {
                "type": "string"
              },
              "timestamp": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "PrimitiveName": {
            "type": "string",
            "enum": [
              "begin-session",
              "whoami",
              "briefing",
              "remember",
              "recall",
              "topics",
              "search",
              "same",
              "retract",
              "revise",
              "recast",
